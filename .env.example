# Generic OpenAI-compatible text model configuration.
# Copy to .env for local private use. Do not commit real keys.

# DeepSeek OpenAI-compatible defaults.
# Official docs use base_url="https://api.deepseek.com" with Chat Completions.
# Current V4 model IDs include deepseek-v4-flash and deepseek-v4-pro.
LLM_API_BASE=https://api.deepseek.com
# LLM_API_KEY=<set locally>
LLM_MODEL=deepseek-v4-flash

# Generic OpenAI-compatible example:
# LLM_API_BASE=https://api.openai.com/v1
# LLM_MODEL=<model-name>

# Optional multi-endpoint failover. Comma, semicolon, newline, or JSON list forms are accepted.
# LLM_API_BASES=https://api-1.example/v1,https://api-2.example/v1
# LLM_API_KEYS=<key-1>,<key-2>

# Generation defaults used by OpenAICompatibleChatClient.
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TOP_P=1.0
LLM_TIMEOUT_S=120
LLM_MAX_ATTEMPTS=3
LLM_BASE_BACKOFF_S=0.6

# Local audit logs. These paths are under artifacts/, which is ignored by git.
LLM_AUDIT_ENABLED=1
LLM_AUDIT_LOG_PATH=artifacts/llm/interactions.jsonl
LLM_USAGE_LOG_PATH=artifacts/llm/token_usage.jsonl
