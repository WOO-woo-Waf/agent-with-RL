# Generic OpenAI-compatible text model configuration.
# Copy to .env for local private use. Do not commit real keys.

# DeepSeek OpenAI-compatible defaults.
# Official docs use base_url="https://api.deepseek.com" with Chat Completions.
# Current V4 model IDs include deepseek-v4-flash and deepseek-v4-pro.
LLM_API_BASE=https://api.deepseek.com
# LLM_API_KEY=<set locally>
LLM_MODEL=deepseek-v4-flash

# Generic OpenAI-compatible example:
# LLM_API_BASE=https://api.openai.com/v1
# LLM_MODEL=<model-name>

# Optional multi-endpoint failover. Comma, semicolon, newline, or JSON list forms are accepted.
# LLM_API_BASES=https://api-1.example/v1,https://api-2.example/v1
# LLM_API_KEYS=<key-1>,<key-2>

# Generation defaults used by OpenAICompatibleChatClient.
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TOP_P=1.0
LLM_TIMEOUT_S=120
LLM_MAX_ATTEMPTS=3
LLM_BASE_BACKOFF_S=0.6

# Local audit logs. These paths are under artifacts/, which is ignored by git.
LLM_AUDIT_ENABLED=1
LLM_AUDIT_LOG_PATH=artifacts/llm/interactions.jsonl
LLM_USAGE_LOG_PATH=artifacts/llm/token_usage.jsonl

# Reusable RAG embedding/vector service configuration.
# Local Windows-native default: Ollama serving qwen3-embedding:4b.
RAG_PROVIDER=ollama
RAG_OLLAMA_BASE_URL=http://127.0.0.1:11434
RAG_OLLAMA_MODEL=qwen3-embedding:4b
RAG_EMBEDDING_DIMENSION=2560
RAG_EMBED_BATCH_SIZE=32
RAG_VECTOR_DB_PATH=artifacts/rag/vector_store.sqlite3
RAG_REQUEST_TIMEOUT_S=120
# Keep disabled by default so normal agent commits do not unexpectedly start a local/remote embedding model.
RAG_AUTO_INDEX_ON_COMMIT=0

# Optional OpenAI-compatible remote embedding service.
# Use this when RAG_PROVIDER=openai-compatible, or keep it for remote rerank.
# RAG_EMBEDDING_BASE_URL=http://127.0.0.1:18080
# RAG_EMBEDDING_API_KEY=<set locally if required>
# RAG_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B

# Optional remote reranker compatible with /v1/rerank.
# RAG_RERANK_BASE_URL=http://127.0.0.1:18080
# RAG_RERANK_API_KEY=<set locally if required>
RAG_RERANK_MODEL=Qwen/Qwen3-Reranker-4B
RAG_RERANK_TOP_N=30

# Optional SSH-managed remote RAG service, adapted from the old narrative-state-engine.
RAG_REMOTE_ON_DEMAND=0
RAG_REMOTE_STOP_AFTER_USE=0
RAG_REMOTE_SSH_HOST=zjgGroup-A800
RAG_REMOTE_SERVICE_DIR=/home/data/nas_hdd/jinglong/waf/novel-embedding-service
RAG_REMOTE_CUDA_DEVICES=6
RAG_REMOTE_STARTUP_TIMEOUT_S=420
